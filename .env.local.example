# Copy this file to .env.local and fill in real values.
# Anything prefixed with NEXT_PUBLIC_ is exposed to the browser. Everything
# else stays server only and must never be sent to the client.

# Supabase project (Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only. Bypasses RLS. Used by the order flow and the admin reads.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gmail SMTP transactional email (Nodemailer).
# EMAIL_PASS must be a Google App Password (16 characters), not your normal
# Gmail password. Generate one at https://myaccount.google.com/apppasswords
# (requires 2-step verification to be on).
EMAIL_USER=yourcompany@gmail.com
EMAIL_PASS=your_google_app_password
# Where the new-order notification (with the screenshot link) is delivered.
# Leave blank to fall back to EMAIL_USER.
COMPANY_NOTIFICATION_EMAIL=owner@your-domain.com

# Bank transfer details shown on the checkout panel.
BANK_ACCOUNT_NAME=Maati & Co.
BANK_ACCOUNT_NUMBER=0000 0000 0000
BANK_IBAN=XX00 0000 0000 0000 0000 0000

# Currency symbol shown across the store. Default is "$".
# For a Pakistani client this becomes "Rs" (see the README note on
# Easypaisa / JazzCash).
NEXT_PUBLIC_CURRENCY_SYMBOL=$

# Optional Easypaisa / JazzCash transfer accounts. Leave blank to hide them.
# These appear next to the bank panel at checkout when set (server only).
EASYPAISA_ACCOUNT=
JAZZCASH_ACCOUNT=

# Base URL of the deployed site (used in email links). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
